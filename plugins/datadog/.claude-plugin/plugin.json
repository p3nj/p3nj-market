{
  "name": "datadog-log-analyst",
  "version": "2.0.1",
  "description": "Query and analyse Datadog logs with full attribute passthrough and streaming accumulator for million-log datasets. Includes a Datadog MCP server and a modular Prismatic-specific analysis skill suite.",
  "author": {
    "name": "Benjamin Wang"
  },
  "homepage": "https://github.com/p3nj/p3nj-market",
  "keywords": ["datadog", "logs", "prismatic", "monitoring", "observability", "sap", "integration"],
  "mcpServers": "./.mcp.json",
  "userConfig": {
    "api_key": {
      "title": "Datadog API Key",
      "description": "Your Datadog API key",
      "sensitive": true,
      "required": true
    },
    "app_key": {
      "title": "Datadog Application Key",
      "description": "Your Datadog Application key",
      "sensitive": true,
      "required": true
    },
    "site": {
      "title": "Datadog Site",
      "description": "Your Datadog site (e.g. datadoghq.com, datadoghq.eu)",
      "sensitive": false,
      "required": true,
      "default": "datadoghq.com"
    }
  }
}
