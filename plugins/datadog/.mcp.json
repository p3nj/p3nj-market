{
  "mcpServers": {
    "datadog": {
      "command": "bash",
      "args": ["-c", "cd ${CLAUDE_PLUGIN_ROOT} && npm install --silent 2>/dev/null && node servers/dd-server.mjs"],
      "env": {
        "DD_API_KEY": "${user_config.api_key}",
        "DD_APP_KEY": "${user_config.app_key}",
        "DD_SITE": "${user_config.site}"
      }
    }
  }
}
